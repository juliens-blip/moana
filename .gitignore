# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
/mcp/airtable-moana-mcp/node_modules

# testing
/coverage

# python
__pycache__/
*.py[cod]

# next.js
/.next/
/out/

# production
/build
/dist
/mcp/airtable-moana-mcp/dist

# misc
.DS_Store
*.pem
/.obsidian/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.kyc
/secrets/

# Broker exports contain credentials and must stay outside version control.
/backup/brokers.csv
/backup/brokers.json

# Graphify keeps the portable graph/report in version control; AST cache is
# machine-local and too noisy to commit.
/graphify-out/cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Windows reserved device names
nul
