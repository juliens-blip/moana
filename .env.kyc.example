# Supabase server credentials. Never expose these values in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-legacy-service-role-key

# Deterministic Crawl4AI worker. No LLM key is required.
KYC_USE_BROWSER=true
KYC_POLL_SECONDS=10
KYC_MAX_SEARCH_RESULTS=4
KYC_MAX_SOURCES=5
KYC_MAX_RETRIES=3
KYC_STALE_JOB_MINUTES=30
